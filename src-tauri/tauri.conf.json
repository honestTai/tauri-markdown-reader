{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdown Reader",
  "version": "0.1.0",
  "identifier": "local.markdown.reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Markdown Reader",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
